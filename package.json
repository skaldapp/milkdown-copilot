{
  "$schema": "https://www.schemastore.org/package",
  "name": "@skaldapp/milkdown-copilot",
  "version": "0.0.21",
  "description": "A Milkdown plugin that provides AI-powered code completions using Mistral AI’s Codestral model with debounced requests and tab-to-accept functionality.",
  "keywords": [
    "milkdown",
    "plugin",
    "copilot",
    "ai",
    "code",
    "completion",
    "editor"
  ],
  "homepage": "https://github.com/skaldapp/milkdown-copilot#readme",
  "bugs": {
    "url": "https://github.com/skaldapp/milkdown-copilot/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skaldapp/milkdown-copilot.git"
  },
  "license": "AGPL-3.0-only",
  "author": "Jerry Bruwes <jbruwes@gmail.com>",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint ."
  },
  "prettier": "@skaldapp/configs/prettierrc",
  "dependencies": {
    "@milkdown/ctx": "^7.21.1",
    "@milkdown/kit": "^7.21.1",
    "monacopilot": "^1.2.12",
    "quasar": "^2.19.3"
  },
  "devDependencies": {
    "@skaldapp/configs": "^1.2.107",
    "@types/node": "^25.8.0",
    "eslint": "^10.4.0"
  }
}
