    "hierarchy",
    "nested",
    "traversal",
    "navigation"
  ],
  "homepage": "https://github.com/skaldapp/milkdown-copilot#readme",
  "bugs": {
    "url": "https://github.com/skaldapp/milkdown-copilot/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skaldapp/milkdown-copilot.git"
  },
  "license": "AGPL-3.0-only",
  "author": "Jerry Bruwes <jbruwes@gmail.com> (https://jbruwes.github.io)",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint ."
  },
  "prettier": "@skaldapp/configs/prettierrc",
  "dependencies": {
    "@milkdown/ctx": "^7.19.2",
